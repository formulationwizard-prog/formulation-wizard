{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-gate.sh",
            "if": "Bash(git commit*)",
            "shell": "bash",
            "timeout": 120,
            "statusMessage": "Running pre-commit gate (Rulebook §VI.29)..."
          }
        ]
      }
    ]
  }
}
